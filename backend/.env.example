# Port for the Express server
PORT=4000

# MongoDB Atlas connection string
# Get yours from: https://cloud.mongodb.com/ → Cluster → Connect → Drivers
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/splitmate?retryWrites=true&w=majority

# Environment: development | production
NODE_ENV=development

# JWT signing secret - generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-jwt-secret-here

# JWT expiration time (7d, 1h, 30m, etc.)
JWT_EXPIRES_IN=7d